{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "tanstack-start-app",
  "compatibility_date": "2025-09-24",
  "compatibility_flags": ["nodejs_compat"],
  "main": "src/server.ts",
  "alias": {
    "tanstack-start-manifest:v": "./dist/server/__tanstack-start-manifest.js",
    "tanstack-start-injected-head-scripts:v": "./dist/server/__tanstack-start-injected-head-scripts.js"
  },
}
